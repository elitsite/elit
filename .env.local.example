# ============================================
# Alina Bloemen — Environment Variables
# ============================================
# Copy this file to .env.local and fill in values.
# NEVER commit .env.local to git!

# ── Supabase ──────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Admin Auth ────────────────────────────────
# bcrypt hash of admin password (generate: node -e "require('bcryptjs').hash('password',10).then(console.log)")
ADMIN_PASSWORD_HASH=
# Random hex string for HMAC session signing (generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ADMIN_SECRET_KEY=

# ── Telegram Notifications ───────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Site URL ─────────────────────────────────
SITE_URL=https://alinabloemen.com

# ── Rabo Smart Pay (OmniKassa 2.0) ────────────
# Master kill switch — set to 'true' ONLY after credentials are configured.
# When 'false' all /api/payment/* routes return 404 and cart-order skips payment.
PAYMENT_ENABLED=false
# HMAC secret used to mint per-order access tokens (status polling & retry).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PAYMENT_ACCESS_SECRET=
# Environment: 'sandbox' or 'production'
RABO_ENVIRONMENT=production
# Refresh token from Rabo Smart Pay Dashboard (long-lived, used to obtain access tokens)
RABO_REFRESH_TOKEN=
# Signing key from Rabo Smart Pay Dashboard (Base64-encoded, for HMAC-SHA512 signature verification)
RABO_SIGNING_KEY=
# Hostname of the Rabo hosted payment page (for open-redirect guard)
# Sandbox: betalen.pay-sandbox.rabobank.nl
# Production: betalen.rabobank.nl
NEXT_PUBLIC_PAYMENT_GATEWAY_HOST=betalen.rabobank.nl

# ── Upstash Redis (optional — fallback to in-memory) ──
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
