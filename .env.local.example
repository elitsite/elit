# ============================================
# Elite Bloemen — Environment Variables
# ============================================
# Copy this file to .env.local and fill in values.
# NEVER commit .env.local to git!

# ── Supabase ──────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Admin Auth ────────────────────────────────
# bcrypt hash of admin password (generate: node -e "require('bcryptjs').hash('password',10).then(console.log)")
ADMIN_PASSWORD_HASH=
# Random hex string for HMAC session signing (generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ADMIN_SECRET_KEY=

# ── Telegram Notifications ───────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Site URL ─────────────────────────────────
SITE_URL=https://elite-bloemen.com

# ── Payment Gateway ───────────────────────────
# Generic payment gateway (replace with your bank's credentials when chosen)
PAYMENT_MERCHANT_ID=
PAYMENT_SECRET_KEY=
# Gateway API endpoints (replace with your bank's URLs)
PAYMENT_GATEWAY_URL=https://gateway.example.com/api/checkout/url
PAYMENT_STATUS_URL=https://gateway.example.com/api/status/order_id

# ── Upstash Redis (optional — fallback to in-memory) ──
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
