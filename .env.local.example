# ============================================
# Elite Bloemen — Environment Variables
# ============================================
# Copy this file to .env.local and fill in values.
# NEVER commit .env.local to git!

# ── Supabase ──────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Admin Auth ────────────────────────────────
# bcrypt hash of admin password (generate: node -e "require('bcryptjs').hash('password',10).then(console.log)")
ADMIN_PASSWORD_HASH=
# Random hex string for HMAC session signing (generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ADMIN_SECRET_KEY=

# ── Telegram Notifications ───────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Site URL ─────────────────────────────────
SITE_URL=https://elite-bloemen.com

# ── Payment Gateway ───────────────────────────
# Master kill switch — set to 'true' ONLY after a real PSP is wired up.
# When 'false' all /api/payment/* routes return 404 and cart-order skips payment.
PAYMENT_ENABLED=false
# HMAC secret used to mint per-order access tokens (status polling & retry).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PAYMENT_ACCESS_SECRET=
# Generic payment gateway (replace with your bank's credentials when chosen)
PAYMENT_MERCHANT_ID=
PAYMENT_SECRET_KEY=
# Gateway API endpoints (replace with your bank's URLs)
PAYMENT_GATEWAY_URL=https://gateway.example.com/api/checkout/url
PAYMENT_STATUS_URL=https://gateway.example.com/api/status/order_id
# Hostname of the PSP (without scheme), used to whitelist redirect URLs
# e.g. pay.mybank.nl — prevents open-redirect if gateway response is forged
PAYMENT_GATEWAY_HOST=
# Same host, exposed to client bundle for the cart page open-redirect guard.
# Must be identical to PAYMENT_GATEWAY_HOST.
NEXT_PUBLIC_PAYMENT_GATEWAY_HOST=

# ── Upstash Redis (optional — fallback to in-memory) ──
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
